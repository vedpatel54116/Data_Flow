    },
    "connection.troubleshoot.1": {
      "localizations": {
        "en": {
          "stringUnit": {
            "value": "Ensure keyboard is connected via USB-C cable (not wireless)",
            "state": "translated"
          }
        }
      }
    },
    "connection.troubleshoot.2": {
      "localizations": {
        "en": {
          "stringUnit": {
            "value": "Grant 'Input Monitoring' permission in System Settings > Privacy & Security",
            "state": "translated"
          }
        }
      }
    },
    "connection.troubleshoot.3": {
      "localizations": {
        "en": {
          "stringUnit": {
            "value": "Check 'Discovered HID Devices' above — look for your keyboard's name, VID, and PID",
            "state": "translated"
          }
        }
      }
    },
    "connection.troubleshoot.4": {
      "localizations": {
        "en": {
          "stringUnit": {
            "value": "If your keyboard shows up but isn't connected, note its VID/PID and report it",
            "state": "translated"
          }
        }
      }
    },
    "connection.troubleshoot.5": {
      "localizations": {
        "en": {
          "stringUnit": {
            "value": "Enable Mock Mode to test all app features without a physical keyboard",
            "state": "translated"
          }
        }
